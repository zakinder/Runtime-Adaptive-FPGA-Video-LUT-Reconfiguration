# Normalize text files
* text=auto

# Markdown and source files
*.md text eol=lf
*.cff text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.c text eol=lf
*.h text eol=lf
*.sv text eol=lf
*.v text eol=lf
*.vhd text eol=lf
*.vhdl text eol=lf

# Binary/document assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.docx binary
*.pptx binary
*.zip binary
*.bit binary
*.bin binary
